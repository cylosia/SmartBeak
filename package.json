{
	"name": "smartbeak",
	"private": true,
	"scripts": {
		"build": "dotenv -c -- turbo build",
		"dev": "dotenv -c -- turbo dev --concurrency 15",
		"type-check": "dotenv -c -- turbo type-check",
		"start": "dotenv -c -- turbo start",
		"test": "turbo test",
		"lint": "biome lint",
		"check": "biome check --write",
		"clean": "turbo clean",
		"format": "biome format --write",
		"knip": "knip"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.28.2",
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@repo/tsconfig": "workspace:*",
		"@types/node": "^25.5.0",
		"dotenv-cli": "^11.0.0",
		"knip": "^6.0.6",
		"turbo": "^2.8.20",
		"typescript": "6.0.2",
		"vitest": "^4.1.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"@prisma/client",
			"@prisma/engines",
			"@swc/core",
			"esbuild",
			"prisma",
			"prisma-zod-generator",
			"sharp"
		],
		"overrides": {
			"hono@<4.12.4": ">=4.12.4",
			"@hono/node-server@<1.19.10": ">=1.19.10",
			"lodash@>=4.0.0 <4.17.23": ">=4.17.23",
			"esbuild@<=0.24.2": ">=0.25.0",
			"trim-newlines@<3.0.1": ">=3.0.1"
		}
	}
}
