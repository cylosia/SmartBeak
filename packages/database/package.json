{
	"dependencies": {
		"@paralleldrive/cuid2": "^3.3.0",
		"@repo/logs": "workspace:*",
		"@prisma/adapter-pg": "^7.4.2",
		"@prisma/client": "7.4.2",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "0.8.3",
		"pg": "^8.20.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.7",
		"@repo/tsconfig": "workspace:*",
		"@types/node": "25.5.0",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.9",
		"prisma": "7.5.0",
		"prisma-zod-generator": "2.1.4"
	},
	"main": "./index.ts",
	"name": "@repo/database",
	"scripts": {
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"generate": "dotenv -c -e ../../.env -- prisma generate --no-hints",
		"drizzle:push": "dotenv -c -e ../../.env -- drizzle-kit push",
		"push": "dotenv -c -e ../../.env -- prisma db push",
		"migrate": "dotenv -c -e ../../.env -- prisma migrate dev",
		"studio": "dotenv -c -e ../../.env -- prisma studio",
		"test": "vitest run",
		"type-check": "tsc --noEmit"
	},
	"types": "./index.ts",
	"version": "0.0.0"
}
